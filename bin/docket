#!/usr/bin/env bash
# docket — thin launcher.
#
# Since the Bash→Python cutover (M6), every command is implemented in the
# Python package `docket` (src/docket/). This shim only resolves an interpreter
# and execs the module; all argument handling, aliasing, version and help live
# in Python (docket.__main__ / docket.cli).
#
# Interpreter resolution order:
#   1. $DOCKET_PYTHON           — explicit override (Homebrew points this at its venv)
#   2. uv run python            — when uv + pyproject are co-located (repo/dev layout)
#   3. python3 -m docket        — installed layout (package on sys.path)

set -euo pipefail

# Resolve symlinks to find this script's directory, then the project root.
REAL_SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$REAL_SCRIPT" ]]; do
  _link="$(readlink "$REAL_SCRIPT")"
  if [[ "$_link" == /* ]]; then REAL_SCRIPT="$_link"; else REAL_SCRIPT="$(dirname "$REAL_SCRIPT")/$_link"; fi
done
SCRIPT_DIR="$(cd "$(dirname "$REAL_SCRIPT")" && pwd)"
DOCKET_CLI_ROOT="${DOCKET_CLI_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
export DOCKET_CLI_ROOT

if [[ -n "${DOCKET_PYTHON:-}" ]]; then
  exec $DOCKET_PYTHON -m docket "$@"
elif command -v uv >/dev/null 2>&1 && [[ -f "$DOCKET_CLI_ROOT/pyproject.toml" ]]; then
  exec uv run --project "$DOCKET_CLI_ROOT" python -m docket "$@"
else
  exec python3 -m docket "$@"
fi
