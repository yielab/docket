#!/usr/bin/env bash
# rack — OpenClaw project agent manager (Modular Edition)
#
# Lifecycle commands:
#   rack list                  List all project agents
#   rack add                   Add a new project agent (interactive)
#   rack info   [id]           Detailed status of one project
#   rack delete [id]           Remove agent and optionally its workspace
#   rack reset  [id]           Clear memory, reset heartbeat (keep identity)
#   rack repair [id]           Fix permissions, routing, missing files
#
#
# Session management:
#   rack scope [id] show       Display current scope
#   rack scope [id] set <key>  Change project scope
#   rack scope [id] reset      Reset to default
#
# Workflows:
#   rack workflow [id] list            List workflows
#   rack workflow [id] create <name>   Create from template
#   rack workflow [id] show <name>     Display workflow
#   rack workflow [id] delete <name>   Remove workflow
#
# Telegram commands:
#   rack wire   [id]           Wire or update a Telegram group binding
#   rack unwire [id]           Remove Telegram binding
#
# Utility commands:
#   rack logs    [id]           View memory logs and gateway entries
#   rack edit    [id]           Open workspace files in $EDITOR
#   rack profile [id] [tier]    Set model profile (economy/standard/premium)
#   rack cost    [id]           Token usage and cost breakdown
#   rack doctor                 System-wide health check
#
# Usage:  rack <command> [agent-id] [args]
#         rack                 (shows list)

# Get script directory for sourcing (handle symlinks)
# Resolve symlinks portably (macOS readlink has no -f) by following the chain.
REAL_SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$REAL_SCRIPT" ]]; do
  _link="$(readlink "$REAL_SCRIPT")"
  if [[ "$_link" == /* ]]; then
    REAL_SCRIPT="$_link"
  else
    REAL_SCRIPT="$(dirname "$REAL_SCRIPT")/$_link"
  fi
done
SCRIPT_DIR="$(cd "$(dirname "$REAL_SCRIPT")" && pwd)"

# Resolve LIB_DIR for both layouts — no installer source-patching required:
#   • RACK_LIB_DIR env override wins (packagers / tests)
#   • installed layout:  <prefix>/bin/rack  +  <prefix>/lib/rack-cli/
#   • repo/clone layout: <repo>/bin/rack    +  <repo>/lib/
if [[ -n "${RACK_LIB_DIR:-}" ]]; then
  LIB_DIR="$RACK_LIB_DIR"
elif [[ -d "$SCRIPT_DIR/../lib/rack-cli" ]]; then
  LIB_DIR="$(cd "$SCRIPT_DIR/../lib/rack-cli" && pwd)"
else
  LIB_DIR="$(cd "$SCRIPT_DIR/../lib" && pwd)"
fi
RACK_CLI_ROOT="${RACK_CLI_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
export RACK_CLI_ROOT LIB_DIR

# Source core modules
source "$LIB_DIR/core/init.sh"
source "$LIB_DIR/core/config.sh"

# Source helper modules
source "$LIB_DIR/helpers/output.sh"
source "$LIB_DIR/helpers/json.sh"
source "$LIB_DIR/helpers/session.sh"
source "$LIB_DIR/helpers/picker.sh"
source "$LIB_DIR/helpers/service.sh"
source "$LIB_DIR/helpers/utils.sh"
source "$LIB_DIR/helpers/workspace.sh"
source "$LIB_DIR/helpers/models.sh"
source "$LIB_DIR/helpers/budget.sh"
source "$LIB_DIR/helpers/secrets.sh"
source "$LIB_DIR/helpers/security.sh"
source "$LIB_DIR/helpers/audit.sh"

# Source command modules
source "$LIB_DIR/commands/list.sh"
source "$LIB_DIR/commands/info.sh"
source "$LIB_DIR/commands/add.sh"
source "$LIB_DIR/commands/delete.sh"
source "$LIB_DIR/commands/wire.sh"
source "$LIB_DIR/commands/unwire.sh"
source "$LIB_DIR/commands/logs.sh"
source "$LIB_DIR/commands/edit.sh"
source "$LIB_DIR/commands/profile.sh"
source "$LIB_DIR/commands/scope.sh"
source "$LIB_DIR/commands/workflow.sh"
source "$LIB_DIR/commands/keys.sh"
source "$LIB_DIR/commands/cost.sh"
source "$LIB_DIR/commands/doctor.sh"
source "$LIB_DIR/commands/gates.sh"
source "$LIB_DIR/commands/audit.sh"
source "$LIB_DIR/commands/eval.sh"
source "$LIB_DIR/commands/install.sh"
source "$LIB_DIR/commands/help.sh"
source "$LIB_DIR/commands/team.sh"
source "$LIB_DIR/commands/maintain.sh"
source "$LIB_DIR/commands/context.sh"
source "$LIB_DIR/commands/snapshot.sh"
source "$LIB_DIR/commands/serve.sh"
source "$LIB_DIR/commands/models.sh"
# Experimental commands — gate behind RACK_EXPERIMENTAL=1
if [[ "${RACK_EXPERIMENTAL:-0}" == "1" ]]; then
  source "$LIB_DIR/commands/experimental/browser.sh"
fi

# Source router
source "$LIB_DIR/core/router.sh"

# Parse arguments
declare -a _ARGS=("$@")
CMD="${_ARGS[0]:-list}"

# Version flag — read from the VERSION file at the repo root.
if [[ "$CMD" == "--version" || "$CMD" == "-V" || "$CMD" == "version" ]]; then
  # VERSION lives at the repo root (clone) or beside lib/ (installed layout).
  _vfile=""
  for _c in "$RACK_CLI_ROOT/VERSION" "$LIB_DIR/VERSION"; do
    [[ -f "$_c" ]] && { _vfile="$_c"; break; }
  done
  if [[ -n "$_vfile" ]]; then
    echo "rack $(cat "$_vfile")"
  else
    echo "rack (version unknown)"
  fi
  exit 0
fi

# Handle --debug flag
if [[ "$CMD" == "--debug" ]]; then
  DEBUG=1
  CMD="${_ARGS[1]:-list}"
  _ARGS=("${_ARGS[@]:1}")
fi

# Route command
route_command "$CMD" "${_ARGS[@]:1}"
